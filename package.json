{
  "name": "tut-auth",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:1": "concurrently \"npm run dev:1:server\" \"npm run dev:1:client\"",
    "dev:1:server": "tsx watch 01-basic-auth/server.ts",
    "dev:1:client": "live-server 01-basic-auth --port=3001 --entry-file=client.html",
    "dev:2": "concurrently \"npm run dev:2:server\" \"npm run dev:2:client\"",
    "dev:2:server": "tsx watch 02-bearer-opaque/server.ts",
    "dev:2:client": "live-server 02-bearer-opaque --port=3002 --entry-file=client.html"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
